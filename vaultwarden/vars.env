DOMAIN="https://vault.mgt.zachneill.com"
SSO_ENABLED=true
SSO_AUTHORITY=https://auth.mgt.zachneill.com
# SSO_SCOPES=profile email vaultwarden groups
SSO_SCOPES=profile email offline_access vaultwarden groups
SSO_PKCE=true
SSO_CLIENT_ID=vaultwarden
SSO_ROLES_ENABLED=true
SSO_ROLES_DEFAULT_TO_USER=true
SSO_ROLES_TOKEN_PATH=/vaultwarden_roles
# SSO_SIGNUPS_MATCH_EMAIL=true 
ROCKET_PORT=8000
SSO_ONLY=true # May need to be set to false for initial setup
SIGNUPS_ALLOWED=false
# In secrets.env:
# SSO_CLIENT_SECRET
# ADMIN_TOKEN